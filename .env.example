FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# PostgreSQL Database (use DATABASE_URL for Render, or individual vars for local dev)
DATABASE_URL=postgresql://user:password@host:5432/rakshak
# OR individual vars:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=rakshak

# Optional: Admin email
ADMIN_EMAIL=admin@rakshak.com
