FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:5001

# MySQL Database (Railway provides MYSQL* vars automatically)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=rakshak
DB_SSL=false

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_ADMIN_EMAILS=admin@rakshak.com
ADMIN_EMAIL=admin@rakshak.com

# Optional runtime controls
ALLOW_DEV_LOGIN=false
KEEP_ALIVE_URL=
VALKYRIE_PIN=

# Free SOS delivery setup
# Email can be sent automatically with a free Gmail App Password or any SMTP provider.
# Gmail steps: enable 2-Step Verification -> create App Password -> paste it below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=your_email@gmail.com
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=20
SMTP_RETRY_ATTEMPTS=2

# Free WhatsApp/SMS mode needs no provider:
# RAKSHAK generates wa.me, sms:, and mailto: emergency share links for contacts.
# Fully automatic SMS/WhatsApp requires a paid/official gateway.

# Optional paid gateway only if you later want automatic SMS/WhatsApp:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
